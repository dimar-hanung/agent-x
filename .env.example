# AgentX — copy to .env.local and fill in values
# cp .env.example .env.local

# Required
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
DATABASE_URL=postgresql://agentx:PASSWORD@127.0.0.1:5432/agentx
SESSION_SECRET=

# Integrations (encrypt Gmail app passwords / OAuth tokens at rest)
# Generate: openssl rand -hex 32
INTEGRATIONS_ENCRYPTION_KEY=

# Optional — Exa web search tools
EXA_API_KEY=

# Optional — Apify social media snapshot tools
APIFY_API_TOKEN=
# APIFY_API_BASE=https://api.apify.com/v2
# APIFY_WORKER_POLL_INTERVAL_MS=15000

# WhatsApp (Evolution API)
WHATSAPP_PROVIDER=unofficial
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=agentx-channel
WHATSAPP_WEBHOOK_SECRET=
AGENTX_PUBLIC_URL=http://localhost:3000
# Same-server Docker webhook target (optional override)
AGENTX_WEBHOOK_URL=

# Scheduler worker
SCHEDULER_POLL_INTERVAL_MS=15000

# Dev seed override (never set in production unless intentional)
# ALLOW_DB_SEED=1
