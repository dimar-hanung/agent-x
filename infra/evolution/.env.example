# Evolution API — copy to .env and fill in values
# cp infra/evolution/.env.example infra/evolution/.env
# See docs/evolution-api-setup.md

AUTHENTICATION_API_KEY=CHANGE_ME_openssl_rand_hex_32
AUTHENTICATION_TYPE=apikey

SERVER_URL=http://127.0.0.1:8080
SERVER_PORT=8080

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution_local_pass@127.0.0.1:5433/evolution
POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=evolution_local_pass

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://127.0.0.1:6380

LOG_LEVEL=ERROR

# Same-server Docker: use host.docker.internal so Evolution can reach AgentX.
# Do not use the public IP (hairpin NAT timeout).
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://host.docker.internal:3000/api/integrations/whatsapp/webhook
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=true
# Must match AgentX WHATSAPP_WEBHOOK_SECRET
WEBHOOK_GLOBAL_HEADERS={"x-webhook-secret":"CHANGE_ME_openssl_rand_hex_16"}
